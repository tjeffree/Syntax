# Copy to `.env.local`. Defaults target the local FastAPI dev server with
# anonymous dev auth — no Firebase project needed.

VITE_API_BASE=http://localhost:8000

# "dev" (anonymous uid in localStorage, sends "dev:<uid>" tokens) or "firebase".
VITE_AUTH_MODE=dev

# --- Firebase (only when VITE_AUTH_MODE=firebase) ---
# Run `npm install firebase` first, then fill these in from your Firebase
# project settings. See docs/FIREBASE_SETUP.md.
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_APP_ID=
