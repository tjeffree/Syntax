# ---------------------------------------------------------------------------
# Syntax backend configuration. Copy to `.env` for local dev; the defaults
# below already give you a fully working local server with NO Firebase project.
# ---------------------------------------------------------------------------

# auth mode: "dev" (accept "dev:<uid>" bearer tokens, incl. anonymous) or
# "firebase" (verify Firebase ID tokens with the Admin SDK).
AUTH_MODE=dev

# store mode: "memory" (JSON file on disk, no external service) or "firestore".
STORE_MODE=memory

# where the memory store persists its JSON (STORE_MODE=memory only).
DATA_FILE=./.data/store.json

# CORS: comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Firebase (only needed when AUTH_MODE=firebase or STORE_MODE=firestore) ---
# Path to a service-account JSON key, OR rely on GOOGLE_APPLICATION_CREDENTIALS /
# Application Default Credentials. See docs/FIREBASE_SETUP.md.
# FIREBASE_CREDENTIALS=./serviceAccount.json
# FIREBASE_PROJECT_ID=your-project-id

# Fixed "server now" for deterministic local testing (ISO-8601 UTC). Leave unset
# in normal operation so the real clock is used.
# SYNTAX_NOW=2026-07-16T09:00:00Z
